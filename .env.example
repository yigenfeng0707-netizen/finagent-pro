# ===========================================
# FinAgent Pro 环境变量模板
# ===========================================
# 复制本文件为 .env 并填入实际值
# 本地开发: cp .env.example .env
# Docker: docker-compose 自动读取此文件

# ---------- AI 模型 API 密钥 (至少配置一个) ----------
DEEPSEEK_API_KEY=your_deepseek_key_here
ZHIPU_API_KEY=your_zhipu_key_here

# 模型参数 (可选)
DEFAULT_MODEL=deepseek-chat
BACKUP_MODEL=glm-4-plus
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/
MAX_TOKENS=4096
TEMPERATURE=0.7

# ---------- 外部数据 (可选) ----------
FINNHUB_API_KEY=your_finnhub_key_here

# ---------- 数据库 (Docker Compose 使用) ----------
POSTGRES_USER=finagent
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=finagent_pro
DATABASE_URL=postgresql+asyncpg://finagent:your_secure_password_here@localhost:5432/finagent_pro

# ---------- Redis ----------
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0

# ---------- JWT 认证 ----------
JWT_SECRET=your_random_jwt_secret_at_least_32_chars
JWT_EXPIRE_HOURS=24

# ---------- 服务配置 ----------
ENV=development
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
