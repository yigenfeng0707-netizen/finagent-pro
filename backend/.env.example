# DeepSeek API (主力) - 必须配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 智谱GLM API (备选) - 建议配置
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# Finnhub API (新闻数据, 可选)
FINNHUB_API_KEY=your_finnhub_api_key_here

# 应用配置
APP_NAME=FinAgent Pro AFAC2026
APP_VERSION=2.0.0
ENV=development

# 后端配置
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 数据库 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://finagent:finagent123@localhost:5432/finagent_pro

# Redis (缓存+任务队列+Celery Broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT 认证
JWT_SECRET=your-jwt-secret-at-least-32-chars-random
JWT_ACCESS_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=30

# 模型配置
DEFAULT_MODEL=deepseek-chat
BACKUP_MODEL=glm-4-plus
MAX_TOKENS=4096
TEMPERATURE=0.7

# 数据缓存
CACHE_ENABLED=True
CACHE_TTL=300

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=json

# 邮件 (用于告警通知)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your_smtp_password
ALERT_EMAIL_FROM=FinAgent Pro <noreply@example.com>

# Stripe (计费系统)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
